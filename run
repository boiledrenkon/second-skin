#!/opt/homebrew/bin/python3.10

import json
import sys, time
import discord
from discord.ext import commands
from src import s, serf, chisel, studio 
from src.util import resolve_user_token, resolve_input
#----------------------------------------
# SET UP
#----------------------------------------
client = commands.Bot(
    command_prefix="*",
    self_bot=True,
    help_command=None,
    intents=None
)
#----------------------------------------
# Ma
#----------------------------------------
@client.command()
async def o_o(ctx, target=None):
    collect_flags = "da"
    editor_key = "1"
    start_date = "0320"
    scroll = await collections(
        ctx,
        client.user,
        collect_flags,
        start_date,
        target
    )
    editor_key = int(editor_key)
    # only using data available in all formats currently
    tablets = chisel.editor(scroll, editor_key)[0]
    studio.summaries(tablets)


@client.command()
async def delete(ctx, target=None):
    collect_flags = "nm"
    start_date = "0311"
    scroll = await collections(
        ctx,
        client.user,
        collect_flags,
        start_date,
        target
    )
    await serf.john_alite(ctx, scroll)
    return
#----------------------------------------
# DIPPERS 
#----------------------------------------
@client.event
async def on_ready():
    print("Online")


@client.command()
async def repeat(ctx, message):
    while True:
        await ctx.send(message)
        time.sleep(.5)


@client.command(pass_context=True)
async def diagnostic(ctx, message):
    #as needed
    print(dir(ctx))
    print(message)
    return


@client.command()
async def poll(ctx, collect_flags):
    scroll = await serf.reap(ctx, client.user, collect_flags)
    s.people(scroll)
    return
#----------------------------------------
# COLLECTORS
#----------------------------------------
# Last Date | 2023-03-11 
#----------------------------------------
@client.command(pass_context=True)
async def sil(ctx, collect_flags, start_date=None, target=None):
    scroll = await collections(
        ctx,
        client.user,
        collect_flags,
        start_date,
        target
    )
    await serf.john_alite(ctx, scroll)
    return


@client.command()
async def col(ctx, collect_flags, editor_key, start_date=None, target=None):
    scroll = await collections(
        ctx,
        client.user,
        collect_flags,
        start_date,
        target
    )
    editor_key = int(editor_key)
    chisel.editor(scroll, editor_key)
    return
#----------------------------------------
# HELPERS
#----------------------------------------
async def collections(
    ctx,
    user,
    collect_flags,
    start_date=None,
    target=None
):
    start_date, target = resolve_input(start_date, target)
    return await serf.reap(
        ctx,
        user,
        collect_flags,
        start_date,
        target
    )
#----------------------------------------
